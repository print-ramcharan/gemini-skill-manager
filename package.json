{
  "name": "gemini-skill-manager",
  "version": "1.0.0",
  "description": "Desktop application to manage active and backup skills for Google Antigravity and Claude Code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "npx -y electron-packager . \"Gemini Skill Manager\" --platform=darwin --overwrite --icon=icon.icns --out=dist",
    "build:win": "npx -y electron-packager . \"Gemini Skill Manager\" --platform=win32 --arch=ia32,x64 --overwrite --icon=icons/windows/icon.ico --out=dist",
    "build:all": "npm run build:mac && npm run build:win",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "gpt-3-encoder": "^1.1.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.print.gemini",
    "productName": "Gemini Skill Manager",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "icon.icns",
      "target": ["dmg","zip"]
    },
    "win": {
      "icon": "icons/windows/icon.ico",
      "target": ["nsis","zip"]
    }
  }
}
